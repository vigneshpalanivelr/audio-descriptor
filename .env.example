# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase (local: run `supabase start` to get these values)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (https://console.developers.google.com/ → redirect URI: http://127.0.0.1:54321/auth/v1/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LLMs — set at least one; LLM_PROVIDER pins a specific one when multiple keys are set
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SARVAM_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_GEMINI_API_KEY=
# Gemini model used for STT when OPENAI_API_KEY is absent (default: gemini-2.5-flash)
# Run `curl https://generativelanguage.googleapis.com/v1beta/models?key=$GOOGLE_GEMINI_API_KEY`
# to list models available to your key, then pick one that supports generateContent + audio.
GEMINI_STT_MODEL=
# Gemini model used for LLM cleanup/title when ANTHROPIC_API_KEY is absent (default: gemini-2.5-flash)
GEMINI_LLM_MODEL=
# Explicit LLM provider override: anthropic | openai | gemini
# When set, this provider is used regardless of which other keys are present.
# When unset, priority is: anthropic → openai → gemini (first key found wins).
LLM_PROVIDER=

# Payments — Razorpay (India / INR)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_PRO_PLUS_LOCAL=

# Payments — Lemon Squeezy (global / USD)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_STARTER=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_PRO_PLUS_LOCAL=

# Background jobs — run `npx inngest-cli@latest dev` to enable locally
# INNGEST_EVENT_KEY=local works with the local Inngest dev server (any value accepted)
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=

# Observability
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Email (Resend — used for daily cost digest)
RESEND_API_KEY=
FROM_EMAIL=hello@quillcast.app
DIGEST_EMAIL=

# Feature flags / cost guardrails
DAILY_COST_CAP_USD=20
ENABLE_SARVAM=false
ENABLE_ELEVENLABS=false
ELEVENLABS_PREMIUM=false
